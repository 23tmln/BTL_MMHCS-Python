# Backend Configuration
PORT=3000
NODE_ENV=development

# MongoDB Atlas
# Get your connection string from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp_db?appName=Cluster0

# JWT Secret - Change this in production!
JWT_SECRET=your_secure_jwt_secret_key_here_change_in_production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email Service (Optional - for welcome emails)
# Get API key from: https://resend.com
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@chatify.com
EMAIL_FROM_NAME=Chatify

# Rate Limiting (Optional)
# Get key from: https://www.arcjet.com
ARCJET_KEY=your_arcjet_key_here
ARCJET_ENV=development
